# Copy to infra/compose/.env.dev (gitignored). Dev-only credentials.

# Postgres (:5433 on host)
POSTGRES_USER=denizcloud
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=denizcloud
POSTGRES_PORT=5433

# MongoDB single-node replica set (:27018 on host).
# Connect from the host with directConnection=true, e.g.:
#   mongodb://denizcloud:devpassword@localhost:27018/?directConnection=true
MONGO_INITDB_ROOT_USERNAME=denizcloud
MONGO_INITDB_ROOT_PASSWORD=devpassword
MONGO_PORT=27018

# Redis (:6380 on host)
REDIS_PASSWORD=devpassword
REDIS_PORT=6380

# Meilisearch (:7700 on host)
MEILI_MASTER_KEY=devmasterkey0000000000000000000000000000
MEILI_ENV=development
MEILI_PORT=7700
DOCKER_PROXY_PORT=23750
DOCKER_PROXY_IMAGE=tecnativa/docker-socket-proxy:0.3.0
