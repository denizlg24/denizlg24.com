# Copy to .env.pi on the Pi. Never commit the real file. Values containing
# URI-reserved characters must be percent-encoded in the three connection URLs.

COMPOSE_PROJECT_NAME=deniz-cloud
API_IMAGE=ghcr.io/denizlg24/deniz-cloud-api:latest
API_VERSION=latest
API_BIND_ADDRESS=127.0.0.1
API_PORT=3001

# Reuse the exact existing production bind-mount directories at cutover.
POSTGRES_DATA_DIR=/srv/deniz-cloud/data/postgres
MONGO_DATA_DIR=/srv/deniz-cloud/data/mongo
MONGOT_DATA_DIR=/srv/deniz-cloud/data/mongot
REDIS_DATA_DIR=/srv/deniz-cloud/data/redis
MEILI_DATA_DIR=/srv/deniz-cloud/data/meilisearch
SSD_STORAGE_PATH=/mnt/ssd/storage
HDD_STORAGE_PATH=/mnt/hdd/storage
BACKUP_DIR=/srv/deniz-cloud/data/backups
HOST_CONTROL_DIR=/var/lib/deniz-cloud
MONGO_REPLICA_KEY_FILE=/etc/deniz-cloud/mongo/replica-keyfile

DB_BIND_ADDRESS=0.0.0.0
POSTGRES_PORT=5433
MONGO_PORT=27018
REDIS_PORT=6380
REDIS_TLS_PORT=6381
ADMINER_PORT=8080
MONGO_EXPRESS_PORT=8081

POSTGRES_USER=denizcloud
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=denizcloud
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=replace-with-a-long-random-password
MONGO_SYNC_USER=sync_reader
MONGO_SYNC_PASSWORD=replace-with-a-long-random-password
MONGOT_PASSWORD=replace-with-a-long-random-password
REDIS_PASSWORD=replace-with-a-long-random-password
MEILI_MASTER_KEY=replace-with-a-long-random-key
MONGO_EXPRESS_USERNAME=admin
MONGO_EXPRESS_PASSWORD=replace-with-a-long-random-password

DATABASE_URL=postgresql://denizcloud:replace-with-percent-encoded-password@postgres:5432/denizcloud
MONGODB_URI=mongodb://sync_reader:replace-with-percent-encoded-password@mongodb:27017/?authSource=admin&directConnection=true
MONGODB_ADMIN_URI=mongodb://root:replace-with-percent-encoded-password@mongodb:27017/?authSource=admin&directConnection=true
REDIS_ADMIN_URL=redis://default:replace-with-percent-encoded-password@redis:6379

BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_URL=https://api.denizlg24.com
COOKIE_DOMAIN=.denizlg24.com
# Preserve the old production TOTP_ENCRYPTION_KEY exactly. Existing encrypted
# project database credentials use that value and must remain decryptable.
DATABASE_CREDENTIAL_ENCRYPTION_KEY=replace-with-the-existing-production-totp-encryption-key
# Preserve the old production JWT_SECRET exactly so issued share links remain valid.
JWT_SECRET=replace-with-the-existing-production-jwt-secret
S3_CREDENTIAL_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
# Preserve both old storage-service values through the first successful API
# startup. They are idempotently migrated to a NULL-project credential row.
S3_ACCESS_KEY_ID=replace-with-the-existing-production-access-key
S3_SECRET_ACCESS_KEY=replace-with-the-existing-production-secret-key
TERMINAL_TICKET_SECRET=replace-with-at-least-32-random-characters
METRICS_NOTIFICATION_WEBHOOK_URL=
CLOUD_ADMIN_URL=https://cloud.denizlg24.com
DISK_MIN_HEADROOM_PERCENT=10
# Optional cloudflared readiness endpoint reachable from the API container.
TUNNEL_HEALTH_URL=

S3_ENDPOINT=https://api.denizlg24.com/v2
S3_REGION=eu-west-1
SSD_HIGH_WATERMARK_PERCENT=80
SSD_TARGET_WATERMARK_PERCENT=70
STORAGE_TIER_MIN_AGE_DAYS=30
STORAGE_TIER_MIN_SIZE_MIB=500
STORAGE_TIER_BATCH_CAP=20
STORAGE_ARCHIVE_MAX_BYTES=2147483648
POSTGRES_EXTERNAL_HOST=postgres.denizlg24.com:5433
MONGODB_EXTERNAL_HOST=mongodb.denizlg24.com:27018
REDIS_EXTERNAL_HOST=redis.denizlg24.com:6380
MONGOT_MAX_INDEXES_PER_PROJECT=5
DB_POOL_MAX=5
SSD_DEVICE=/dev/nvme0n1p1
HDD_DEVICES=
MICROSD_DEVICE=/dev/mmcblk0p2

# TLS is accept-both. Provision certs before changing these from disabled.
POSTGRES_TLS_MODE=off
MONGO_TLS_MODE=disabled
REDIS_TLS_MODE=disabled
POSTGRES_TLS_DIR=/etc/deniz-cloud/tls/postgres
MONGO_TLS_DIR=/etc/deniz-cloud/tls/mongodb
REDIS_TLS_DIR=/etc/deniz-cloud/tls/redis

POSTGRES_IMAGE=postgres:16-alpine
MONGO_IMAGE=mongo:8.2.11
MONGOT_IMAGE=mongodb/mongodb-community-search:1.70.1
REDIS_IMAGE=redis:7-alpine
MEILI_IMAGE=getmeili/meilisearch:v1.38
DOCKER_PROXY_IMAGE=ghcr.io/tecnativa/docker-socket-proxy:0.3.0
ADMINER_IMAGE=adminer:5.4.1
MONGO_EXPRESS_IMAGE=mongo-express:1.0.2-20-alpine3.19

POSTGRES_SHARED_BUFFERS=64MB
POSTGRES_WORK_MEM=4MB
POSTGRES_MAINTENANCE_WORK_MEM=32MB
POSTGRES_EFFECTIVE_CACHE_SIZE=256MB
POSTGRES_MAX_CONNECTIONS=50
POSTGRES_IDLE_IN_TRANSACTION_TIMEOUT=60s
MONGO_SEARCH_ENABLED=true
MONGO_WIREDTIGER_CACHE_GB=0.25
MONGOT_JVM_FLAGS=-Xms64m -Xmx128m
REDIS_MAXMEMORY=128mb
MEILI_ENV=production

POSTGRES_MEMORY_LIMIT=192m
MONGO_MEMORY_LIMIT=384m
MONGOT_MEMORY_LIMIT=192m
REDIS_MEMORY_LIMIT=144m
REDIS_AUDIT_MEMORY_LIMIT=16m
MEILI_MEMORY_LIMIT=128m
DOCKER_PROXY_MEMORY_LIMIT=24m
API_MEMORY_LIMIT=450m
ADMINER_MEMORY_LIMIT=48m
MONGO_EXPRESS_MEMORY_LIMIT=64m
