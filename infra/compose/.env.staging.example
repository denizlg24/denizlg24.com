# Copy to .env.staging on the Pi. This stack uses isolated paths and alternate
# loopback-only ports so it cannot replace or expose the old production stack.

COMPOSE_PROJECT_NAME=cloud-staging
API_IMAGE=ghcr.io/denizlg24/deniz-cloud-api:latest
API_VERSION=staging
API_BIND_ADDRESS=127.0.0.1
API_PORT=13001

POSTGRES_DATA_DIR=/srv/deniz-cloud-staging/data/postgres
MONGO_DATA_DIR=/srv/deniz-cloud-staging/data/mongo
MONGOT_DATA_DIR=/srv/deniz-cloud-staging/data/mongot
REDIS_DATA_DIR=/srv/deniz-cloud-staging/data/redis
MEILI_DATA_DIR=/srv/deniz-cloud-staging/data/meilisearch
SSD_STORAGE_PATH=/srv/deniz-cloud-staging/storage/ssd
HDD_STORAGE_PATH=/srv/deniz-cloud-staging/storage/hdd
BACKUP_DIR=/srv/deniz-cloud-staging/backups
HOST_CONTROL_DIR=/srv/deniz-cloud-staging/host-control
MONGO_REPLICA_KEY_FILE=/srv/deniz-cloud-staging/secrets/mongo-replica-keyfile

DB_BIND_ADDRESS=127.0.0.1
POSTGRES_PORT=15433
MONGO_PORT=17018
REDIS_PORT=16380
REDIS_TLS_PORT=16381
ADMINER_PORT=18080
MONGO_EXPRESS_PORT=18081

POSTGRES_USER=denizcloud
POSTGRES_PASSWORD=staging-postgres-change-me
POSTGRES_DB=denizcloud
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=staging-mongo-root-change-me
MONGO_SYNC_USER=sync_reader
MONGO_SYNC_PASSWORD=staging-mongo-sync-change-me
MONGOT_PASSWORD=staging-mongot-change-me
REDIS_PASSWORD=staging-redis-change-me
MEILI_MASTER_KEY=staging-meili-master-key-change-me
MONGO_EXPRESS_USERNAME=admin
MONGO_EXPRESS_PASSWORD=staging-mongo-express-change-me

DATABASE_URL=postgresql://denizcloud:staging-postgres-change-me@postgres:5432/denizcloud
MONGODB_URI=mongodb://sync_reader:staging-mongo-sync-change-me@mongodb:27017/?authSource=admin&directConnection=true
MONGODB_ADMIN_URI=mongodb://root:staging-mongo-root-change-me@mongodb:27017/?authSource=admin&directConnection=true
REDIS_ADMIN_URL=redis://default:staging-redis-change-me@redis:6379

BETTER_AUTH_SECRET=staging-better-auth-secret-at-least-32-characters
BETTER_AUTH_URL=http://127.0.0.1:13001
COOKIE_DOMAIN=localhost
TERMINAL_TICKET_SECRET=staging-terminal-ticket-secret-32-characters
METRICS_NOTIFICATION_WEBHOOK_URL=

S3_ENDPOINT=http://127.0.0.1:13001/v2
S3_REGION=eu-west-1
REDIS_EXTERNAL_HOST=127.0.0.1:16380
DB_POOL_MAX=5
SSD_DEVICE=/dev/nvme0n1p1
HDD_DEVICES=
MICROSD_DEVICE=/dev/mmcblk0p2

POSTGRES_TLS_MODE=off
MONGO_TLS_MODE=disabled
REDIS_TLS_MODE=disabled
POSTGRES_TLS_DIR=/srv/deniz-cloud-staging/tls/postgres
MONGO_TLS_DIR=/srv/deniz-cloud-staging/tls/mongodb
REDIS_TLS_DIR=/srv/deniz-cloud-staging/tls/redis

POSTGRES_IMAGE=postgres:16-alpine
MONGO_IMAGE=mongo:8.2.11
MONGOT_IMAGE=mongodb/mongodb-community-search:1.70.1
REDIS_IMAGE=redis:7-alpine
MEILI_IMAGE=getmeili/meilisearch:v1.38
DOCKER_PROXY_IMAGE=tecnativa/docker-socket-proxy:0.3.0
ADMINER_IMAGE=adminer:5.4.1
MONGO_EXPRESS_IMAGE=mongo-express:1.0.2-20-alpine3.19

POSTGRES_SHARED_BUFFERS=64MB
POSTGRES_WORK_MEM=4MB
POSTGRES_MAINTENANCE_WORK_MEM=32MB
POSTGRES_EFFECTIVE_CACHE_SIZE=256MB
POSTGRES_MAX_CONNECTIONS=50
POSTGRES_IDLE_IN_TRANSACTION_TIMEOUT=60s
MONGO_SEARCH_ENABLED=true
MONGO_WIREDTIGER_CACHE_GB=0.25
MONGOT_JVM_FLAGS=-Xms64m -Xmx128m
REDIS_MAXMEMORY=128mb
MEILI_ENV=production

POSTGRES_MEMORY_LIMIT=192m
MONGO_MEMORY_LIMIT=384m
MONGOT_MEMORY_LIMIT=192m
REDIS_MEMORY_LIMIT=144m
REDIS_AUDIT_MEMORY_LIMIT=16m
MEILI_MEMORY_LIMIT=128m
DOCKER_PROXY_MEMORY_LIMIT=24m
API_MEMORY_LIMIT=450m
ADMINER_MEMORY_LIMIT=48m
MONGO_EXPRESS_MEMORY_LIMIT=64m
