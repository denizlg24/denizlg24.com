{
  "name": "denizlg24.com",
  "private": true,
  "scripts": {
    "agent-memory:migrate": "cd apps/web && bun --env-file=../../.env scripts/migrate-agent-memory.ts",
    "papers:migrate": "cd apps/web && bun --env-file=../../.env scripts/migrate-papers-from-notes.ts",
    "build": "bun --env-file=.env turbo run build",
    "dev": "bun --env-file=.env turbo run dev",
    "lint": "bun --env-file=.env turbo run lint",
    "check-types": "bun --env-file=.env turbo run typecheck",
    "test": "bun --env-file=.env turbo run test",
    "format-and-lint": "biome check .",
    "format-and-lint:fix": "biome check . --write",
    "postinstall": "node scripts/fetch-tectonic.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "husky": "^9.1.7",
    "knip": "^6.29.0",
    "lint-staged": "^17.1.1",
    "turbo": "^2.10.6",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "cmdk": "1.1.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "lint-staged": {
    "*": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
  }
}
